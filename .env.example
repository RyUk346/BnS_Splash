# ── Google Sheets ────────────────────────────────────────────────
# Apps Script web app URL (see apps-script/Code.gs for setup steps)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# ── UniFi ────────────────────────────────────────────────────────
# "cloud" = via api.ui.com Cloud Connector Proxy (recommended, no port
#           forwarding needed). "direct" = straight to the console IP.
UNIFI_MODE=cloud

# Cloud mode: create the key at unifi.ui.com -> (profile icon) -> API Keys
# Direct mode: create it in Network -> Settings -> Control Plane -> Integrations
UNIFI_API_KEY=your-api-key-here

# Cloud mode only: your console ID.
# Find it with:
#   curl -s https://api.ui.com/v1/hosts -H "X-API-Key: YOUR_KEY"
# and copy the "id" field of your console.
UNIFI_CONSOLE_ID=

# Direct mode only: console address reachable from this VPS
# UNIFI_CONTROLLER_URL=https://your-console-public-ip

# Optional: leave blank to auto-detect the first site
UNIFI_SITE_ID=

# How long a guest stays authorized (minutes). 1440 = 24h
AUTH_MINUTES=1440

# Where guests land after connecting, if UniFi didn't pass an original URL
NEXT_PUBLIC_REDIRECT_URL=https://hyperglow.co.uk

# Serve the app under a subpath (leave empty to serve at the domain root).
# Example: /SplashPage/BnS  →  page lives at https://yourdomain/SplashPage/BnS
# NOTE: requires a rebuild (npm run build) after changing.
NEXT_PUBLIC_BASE_PATH=
